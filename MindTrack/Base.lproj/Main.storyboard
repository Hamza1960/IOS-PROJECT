        </scene>
        <!--Settings-->
        <scene sceneID="set-nav-scene">
            <objects>
                <navigationController id="set-nav" sceneMemberID="viewController">
                    <tabBarItem key="tabBarItem" title="Settings" image="gearshape.fill" catalog="system" id="set-tab-item"/>
                    <navigationBar key="navigationBar" contentMode="scaleToFill" id="set-nav-bar">
