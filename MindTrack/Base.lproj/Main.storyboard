        </scene>
        <!--History View Controller-->
        <scene sceneID="hist-vc-scene">
            <objects>
                <viewController id="hist-vc-id" customClass="HistoryViewController" customModule="MindTrack" customModuleProvider="target" sceneMemberID="viewController">
