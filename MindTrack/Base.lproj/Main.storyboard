        </scene>
        <!--Settings View Controller-->
        <scene sceneID="set-vc-scene">
            <objects>
                <viewController id="set-vc-id" customClass="SettingsViewController" customModule="MindTrack" customModuleProvider="target" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="set-view">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <viewLayoutGuide key="safeArea" id="set-safe-area"/>
