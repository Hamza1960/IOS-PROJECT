<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB" version="3.0" toolsVersion="21507" targetRuntime="AppleSDK" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES" initialViewController="TabBarController">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="21505"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="System colors in branding assets" minToolsVersion="11.0"/>
    </dependencies>
    <scenes>
        <!--Tab Bar Controller-->
        <scene sceneID="TabBarScene">
            <objects>
                <tabBarController id="TabBarController" customClass="UITabBarController" sceneMemberID="viewController">
                    <tabBar key="tabBar" contentMode="scaleToFill" insetsLayoutMarginsFromSafeArea="NO" id="TabBar">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="49"/>
                        <autoresizingMask key="autoresizingMask"/>
                        <color key="tintColor" red="0.40" green="0.49" blue="0.92" alpha="1"/>
                    </tabBar>
                    <connections>
                        <segue destination="HomeNav" kind="relationship" relationship="viewControllers" id="TabToHome"/>
                        <segue destination="ChartNav" kind="relationship" relationship="viewControllers" id="TabToCharts"/>
                        <segue destination="HistoryNav" kind="relationship" relationship="viewControllers" id="TabToHistory"/>
                        <segue destination="SettingsNav" kind="relationship" relationship="viewControllers" id="TabToSettings"/>
                    </connections>
                </tabBarController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="TabBarFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="0" y="0"/>
        </scene>
        
        <!--Home Navigation Controller-->
        <scene sceneID="HomeNavScene">
            <objects>
                <navigationController automaticallyAdjustsScrollViewInsets="NO" id="HomeNav" sceneMemberID="viewController">
                    <tabBarItem key="tabBarItem" title="Home" image="house.fill" id="HomeTabItem"/>
                    <navigationBar key="navigationBar" contentMode="scaleToFill" insetsLayoutMarginsFromSafeArea="NO" id="HomeNavBar">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="44"/>
                        <autoresizingMask key="autoresizingMask"/>
                    </navigationBar>
                    <connections>
                        <segue destination="HomeVC" kind="relationship" relationship="rootViewController" id="HomeNavToHome"/>
                    </connections>
                </navigationController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="HomeNavFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="-600" y="400"/>
        </scene>
        
        <!--Home View Controller-->
        <scene sceneID="HomeVCScene">
            <objects>
                <viewController id="HomeVC" customClass="HomeViewController" customModule="MindTrack" customModuleProvider="target" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="HomeView">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                        <viewLayoutGuide key="safeArea" id="HomeViewSafeArea"/>
                    </view>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="HomeVCFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="-600" y="800"/>
        </scene>
        
        <!--Charts Navigation Controller-->
        <scene sceneID="ChartNavScene">
            <objects>
                <navigationController automaticallyAdjustsScrollViewInsets="NO" id="ChartNav" sceneMemberID="viewController">
                    <tabBarItem key="tabBarItem" title="Charts" image="chart.line.uptrend.xyaxis" id="ChartTabItem"/>
                    <navigationBar key="navigationBar" contentMode="scaleToFill" insetsLayoutMarginsFromSafeArea="NO" id="ChartNavBar">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="44"/>
                        <autoresizingMask key="autoresizingMask"/>
                    </navigationBar>
                    <connections>
                        <segue destination="ChartVC" kind="relationship" relationship="rootViewController" id="ChartNavToChart"/>
                    </connections>
                </navigationController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="ChartNavFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="0" y="400"/>
        </scene>
        
        <!--Chart View Controller-->
        <scene sceneID="ChartVCScene">
            <objects>
                <viewController id="ChartVC" customClass="ChartViewController" customModule="MindTrack" customModuleProvider="target" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="ChartView">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                        <viewLayoutGuide key="safeArea" id="ChartViewSafeArea"/>
                    </view>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="ChartVCFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="0" y="800"/>
        </scene>
        
        <!--History Navigation Controller-->
        <scene sceneID="HistoryNavScene">
            <objects>
                <navigationController automaticallyAdjustsScrollViewInsets="NO" id="HistoryNav" sceneMemberID="viewController">
                    <tabBarItem key="tabBarItem" title="History" image="book.fill" id="HistoryTabItem"/>
                    <navigationBar key="navigationBar" contentMode="scaleToFill" insetsLayoutMarginsFromSafeArea="NO" id="HistoryNavBar">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="44"/>
                        <autoresizingMask key="autoresizingMask"/>
                    </navigationBar>
                    <connections>
                        <segue destination="HistoryVC" kind="relationship" relationship="rootViewController" id="HistoryNavToHistory"/>
                    </connections>
                </navigationController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="HistoryNavFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="600" y="400"/>
        </scene>
        
        <!--History View Controller-->
        <scene sceneID="HistoryVCScene">
            <objects>
                <viewController id="HistoryVC" customClass="HistoryViewController" customModule="MindTrack" customModuleProvider="target" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="HistoryView">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                        <viewLayoutGuide key="safeArea" id="HistoryViewSafeArea"/>
                    </view>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="HistoryVCFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="600" y="800"/>
        </scene>
        
        <!--Settings Navigation Controller-->
        <scene sceneID="SettingsNavScene">
            <objects>
                <navigationController automaticallyAdjustsScrollViewInsets="NO" id="SettingsNav" sceneMemberID="viewController">
                    <tabBarItem key="tabBarItem" title="Settings" image="gearshape.fill" id="SettingsTabItem"/>
                    <navigationBar key="navigationBar" contentMode="scaleToFill" insetsLayoutMarginsFromSafeArea="NO" id="SettingsNavBar">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="44"/>
                        <autoresizingMask key="autoresizingMask"/>
                    </navigationBar>
                    <connections>
                        <segue destination="SettingsVC" kind="relationship" relationship="rootViewController" id="SettingsNavToSettings"/>
                    </connections>
                </navigationController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="SettingsNavFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="1200" y="400"/>
        </scene>
        
        <!--Settings View Controller-->
        <scene sceneID="SettingsVCScene">
            <objects>
                <viewController id="SettingsVC" customClass="SettingsViewController" customModule="MindTrack" customModuleProvider="target" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="SettingsView">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                        <viewLayoutGuide key="safeArea" id="SettingsViewSafeArea"/>
                    </view>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="SettingsVCFirstResponder" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="1200" y="800"/>
        </scene>
    </scenes>
    <resources>
        <systemColor name="systemBackgroundColor">
            <color white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
        </systemColor>
    </resources>
</document>
